{
  "name": "@epicai/legion",
  "version": "1.3.0",
  "description": "Epic AI\u00ae Legion \u2014 35,835 tools. One self-hosted MCP server. Intelligent Virtual Assistant (IVA) integration layer for AI agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./retrieval/adapters/qdrant": {
      "import": "./dist/retrieval/adapters/QdrantAdapter.js",
      "types": "./dist/retrieval/adapters/QdrantAdapter.d.ts"
    },
    "./memory/adapters/redis-mongo": {
      "import": "./dist/memory/adapters/RedisMongoAdapter.js",
      "types": "./dist/memory/adapters/RedisMongoAdapter.d.ts"
    },
    "./mcp-servers/*": {
      "import": "./dist/mcp-servers/*.js",
      "types": "./dist/mcp-servers/*.d.ts"
    },
    "./harness": {
      "import": "./dist/harness/index.js",
      "types": "./dist/harness/index.d.ts"
    },
    "./gateway": {
      "import": "./dist/gateway/index.js",
      "types": "./dist/gateway/index.d.ts"
    },
    "./adapter-catalog": {
      "import": "./adapter-catalog.json",
      "default": "./adapter-catalog.json"
    }
  },
  "bin": {
    "legion": "dist/bin/setup.js",
    "legion-gateway": "dist/bin/gateway.js",
    "epicai-harness": "dist/harness/cli.js"
  },
  "files": [
    "dist",
    "adapter-catalog.json",
    "adapter-catalog.json.sig",
    "mcp-registry.json",
    "scripts/sign-catalog.mjs",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CONTRIBUTING.md",
    "DEVELOPER_GUIDE.md",
    "CHANGELOG.md",
    "TRADEMARK.md",
    "LICENSE-ADAPTERS",
    "PRIVACY.md",
    "SECURITY.md",
    "docs/TEST-PROTOCOL.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/protectnil/epic-ai-legion.git"
  },
  "homepage": "https://legion.epic-ai.io",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "iva",
    "intelligent-virtual-assistant",
    "ai-assistants",
    "agent",
    "orchestration",
    "federation",
    "autonomy",
    "governance",
    "retrieval",
    "rag",
    "audit",
    "llm",
    "ai",
    "epic-ai",
    "legion",
    "self-hosted",
    "tool-router",
    "cybersecurity",
    "devops",
    "typescript"
  ],
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "picocolors": "^1.1.1",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@qdrant/js-client-rest": ">=1.8.0",
    "@xenova/transformers": ">=2.17.0",
    "mongodb": ">=6.3.0",
    "redis": ">=4.6.0"
  },
  "peerDependenciesMeta": {
    "@qdrant/js-client-rest": {
      "optional": true
    },
    "@xenova/transformers": {
      "optional": true
    },
    "redis": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/node": "^20.0.0",
    "@types/redis": "^4.0.10",
    "mongodb": "^7.1.0",
    "openapi-types": "^12.1.3",
    "redis": "^5.11.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "release:patch": "npm run build && npm version patch && npm publish --access public",
    "release:minor": "npm run build && npm version minor && npm publish --access public",
    "release:major": "npm run build && npm version major && npm publish --access public",
    "build": "tsc",
    "pretest": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:harness": "npx tsx tests/harness-check.ts",
    "test:compliance": "npx tsx adapter-test-harness/run.ts --all",
    "test:compliance:validate": "npx tsx adapter-test-harness/run.ts --validate --report",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "eval": "node dist/eval/routing-eval.js",
    "eval:tier3": "node dist/eval/tier3-eval.js"
  },
  "bugs": {
    "url": "https://github.com/protectnil/epic-ai-legion/security/advisories/new"
  }
}
