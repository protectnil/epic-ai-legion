{
  "name": "@epicai/core",
  "version": "0.1.2",
  "description": "Epic AI® Zero LLM Context MCP Orchestrator — Intelligent Virtual Assistant (IVA) for all 10 (ISC)² security domains. Local SLM routes tools, cloud LLM responds. Security data never leaves your infrastructure.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./retrieval/adapters/qdrant": {
      "import": "./dist/retrieval/adapters/QdrantAdapter.js",
      "types": "./dist/retrieval/adapters/QdrantAdapter.d.ts"
    },
    "./memory/adapters/redis-mongo": {
      "import": "./dist/memory/adapters/RedisMongoAdapter.js",
      "types": "./dist/memory/adapters/RedisMongoAdapter.d.ts"
    },
    "./mcp-servers/*": {
      "import": "./dist/mcp-servers/*.js",
      "types": "./dist/mcp-servers/*.d.ts"
    },
    "./harness": {
      "import": "./dist/harness/index.js",
      "types": "./dist/harness/index.d.ts"
    }
  },
  "bin": {
    "epic-ai": "./dist/bin/setup.js",
    "epicai-harness": "./dist/harness/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/protectnil/epic-ai-core.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "orchestration",
    "federation",
    "autonomy",
    "governance",
    "retrieval",
    "rag",
    "audit",
    "llm",
    "ai",
    "epic-ai"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@qdrant/js-client-rest": ">=1.8.0",
    "mongodb": ">=6.3.0",
    "redis": ">=4.6.0"
  },
  "peerDependenciesMeta": {
    "@qdrant/js-client-rest": {
      "optional": true
    },
    "redis": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/redis": "^4.0.10",
    "mongodb": "^7.1.0",
    "redis": "^5.11.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsc",
    "pretest": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:harness": "npx tsx tests/harness-check.ts",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  }
}
