{
  "name": "@epicai/core",
  "version": "0.4.1",
  "description": "Epic AI® IVA Core — the Intelligent Virtual Assistant that replaces dashboards and manual analysis. 472 enterprise adapters. Local SLM orchestrates, cloud LLM responds. Your data never leaves.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./retrieval/adapters/qdrant": {
      "import": "./dist/retrieval/adapters/QdrantAdapter.js",
      "types": "./dist/retrieval/adapters/QdrantAdapter.d.ts"
    },
    "./memory/adapters/redis-mongo": {
      "import": "./dist/memory/adapters/RedisMongoAdapter.js",
      "types": "./dist/memory/adapters/RedisMongoAdapter.d.ts"
    },
    "./mcp-servers/*": {
      "import": "./dist/mcp-servers/*.js",
      "types": "./dist/mcp-servers/*.d.ts"
    },
    "./harness": {
      "import": "./dist/harness/index.js",
      "types": "./dist/harness/index.d.ts"
    },
    "./gateway": {
      "import": "./dist/gateway/index.js",
      "types": "./dist/gateway/index.d.ts"
    },
    "./adapter-catalog": {
      "import": "./adapter-catalog.json",
      "default": "./adapter-catalog.json"
    }
  },
  "bin": {
    "epic-ai": "./dist/bin/setup.js",
    "epic-ai-gateway": "./dist/bin/gateway.js",
    "epicai-harness": "./dist/harness/cli.js"
  },
  "files": [
    "dist",
    "adapter-catalog.json",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md",
    "TRADEMARK.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/protectnil/epic-ai-core.git"
  },
  "homepage": "https://epic-ai.io",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "iva",
    "intelligent-virtual-assistant",
    "ai-assistants",
    "agent",
    "orchestration",
    "federation",
    "autonomy",
    "governance",
    "retrieval",
    "rag",
    "audit",
    "llm",
    "ai",
    "epic-ai",
    "cybersecurity",
    "devops",
    "typescript"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@qdrant/js-client-rest": ">=1.8.0",
    "mongodb": ">=6.3.0",
    "redis": ">=4.6.0"
  },
  "peerDependenciesMeta": {
    "@qdrant/js-client-rest": {
      "optional": true
    },
    "redis": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/redis": "^4.0.10",
    "mongodb": "^7.1.0",
    "redis": "^5.11.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "npx tsx scripts/generate-catalog.ts",
    "pretest": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:harness": "npx tsx tests/harness-check.ts",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  }
}
