# Epic AI Core — Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: debug | info | warn | error | off (default: warn)
EPICAI_LOG=info

# Loki remote logging (optional — stderr always works)
# All three required to enable Loki transport.
EPICAI_LOG_LOKI_URL=https://logs-prod-021.grafana.net/loki/api/v1/push
EPICAI_LOG_LOKI_USER=1221670
EPICAI_LOG_LOKI_TOKEN=

# ---------------------------------------------------------------------------
# Integration tests
# ---------------------------------------------------------------------------
# Model for integration tests (default: qwen2.5:7b)
EPICAI_TEST_MODEL=qwen2.5:7b

# Ollama base URL (default: http://localhost:11434)
# EPICAI_OLLAMA_URL=http://localhost:11434
